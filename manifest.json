{
  "manifest_version": 3,
  "name": "Chess Assist - Stockfish Analysis",
  "version": "1.1.0",
  "description": "Real-time Stockfish analysis for Chess.com games",
  "permissions": [
    "storage",
    "activeTab",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.chess.com/*",
    "https://chess.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/game/live/*",
        "https://www.chess.com/play/*",
        "https://www.chess.com/game/daily/*",
        "https://www.chess.com/live/*",
        "https://www.chess.com/daily/*"
      ],
      "js": [
        "utils/fen-parser.js",
        "utils/board-reader.js",
        "overlay/overlay.js",
        "content.js"
      ],
      "css": [
        "overlay/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "stockfish/stockfish-worker.js",
        "stockfish/stockfish-engine.js"
      ],
      "matches": ["https://www.chess.com/*", "https://chess.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
